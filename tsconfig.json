{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"],
  "exclude": [
    "web_form/**",
    "src/components/**",
    "src/hooks/**",
    "src/lib/**",
    "src/routes/**",
    "src/router.tsx",
    "src/routeTree.gen.ts",
    "src/server.ts",
    "src/start.ts"
  ]
}
